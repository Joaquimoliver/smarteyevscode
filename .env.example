# ──────────────────────────────────────────────
#  SmartEye — Configurações do Servidor
#  Copie este arquivo para .env e ajuste os valores
# ──────────────────────────────────────────────

# Porta do servidor (padrão: 3000)
PORT=3000

# Senha do dashboard (deixe vazio para sem autenticação)
DASHBOARD_PASSWORD=smarteye123

# HTTPS: coloque os caminhos dos certificados para ativar
# Execute: npm run setup-https  para gerar certificados locais
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem

# Máximo de eventos no log (padrão: 200)
MAX_EVENTS=200

# Arquivo para persistir eventos (deixe vazio para desativar)
EVENTS_FILE=./data/events.json
